{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "Render Pass",
	"description": "Instructions to create a render pass.",
	"type": "object",
	"required": ["attachments", "subpasses", "dependencies"],
	"additionalProperties": false,
	"properties": {
		"attachments": {
			"type": "array",
			"description": "The attachments used by the render pass.",
			"items": {
				"type": "object",
				"additionalProperties": false,
				"properties": {
					"format": {
						"$ref": "#/$defs/Format",
						"description": "The format of the image view that will be used for the attachment.",
						"default": "R8G8B8A8SRGB"
					},
					"initialLayout": {
						"$ref": "#/$defs/ImageLayout",
						"description": "The layout the attachment image subresource will be in when a render pass instance begins.",
						"default": "Undefined"
					},
					"finalLayout": {
						"$ref": "#/$defs/ImageLayout",
						"description": "The layout the attachment image subresource will be transitioned to when a render pass instance ends.",
						"default": "ShaderReadOnlyOptimal"
					},
					"samples": {
						"enum": [1, 2, 4, 8, 16, 32, 64],
						"description": "Value specifying the number of samples of the image.",
						"default": 1
					},
					"loadOp": {
						"$ref": "#/$defs/AttachmentLoadOp",
						"description": "Vulkan.AttachmentLoadOp value specifying how the contents of color and depth components of the attachment are treated at the beginning of the subpass where it is first used.",
						"default": "Clear"
					},
					"storeOp": {
						"$ref": "#/$defs/AttachmentStoreOp",
						"description": "Vulkan.AttachmentStoreOp value specifying how the contents of color and depth components of the attachment are treated at the end of the subpass where it is last used.",
						"default": "Store"
					},
					"stencilLoadOp": {
						"$ref": "#/$defs/AttachmentLoadOp",
						"description": "Vulkan.AttachmentLoadOp value specifying how the contents of stencil components of the attachment are treated at the beginning of the subpass where it is first used.",
						"default": "DontCare"
					},
					"stencilStoreOp": {
						"$ref": "#/$defs/AttachmentStoreOp",
						"description": "Vulkan.AttachmentStoreOp value specifying how the contents of stencil components of the attachment are treated at the end of the last subpass where it is used.",
						"default": "DontCare"
					}
				}
			}
		},
		"subpasses": {
			"type": "array",
			"description": "An array describing each subpass.",
			"items": {
				"type": "object",
				"required": ["pipelineBindPoint", "colorAttachments"],
				"additionalProperties": false,
				"properties": {
					"pipelineBindPoint": {
						"$ref": "#/$defs/PipelineBindPoint",
						"description": "The pipeline type supported for this subpass."
					},
					"inputAttachments": {
						"type": "array",
						"description": "An array of objects defining the input attachments for this subpass and their layouts.",
						"items": {
							"$ref": "#/$defs/AttachmentReference"
						},
						"default": []
					},
					"colorAttachments": {
						"type": "array",
						"description": "An array of objects defining the color attachments for this subpass and their layouts.",
						"items": {
							"$ref": "#/$defs/AttachmentReference"
						}
					},
					"resolveAttachments": {
						"type": "array",
						"description": "An array of objects defining the resolve attachments for this subpass and their layouts.",
						"items": {
							"$ref": "#/$defs/AttachmentReference"
						},
						"default": []
					},
					"depthStencilAttachment": {
						"$ref": "#/$defs/AttachmentReference",
						"description": "Object specifying the depth/stencil attachment for this subpass and its layout.",
						"default": null
					},
					"preserveAttachments": {
						"type": "array",
						"description": "An array of render pass attachment indices identifying attachments that are not used by this subpass, but whose contents must be preserved throughout the subpass.",
						"items": {
							"type": "integer"
						},
						"default": []
					}
				}
			}
		},
		"dependencies": {
			"type": "array",
			"description": "An array describing the memory dependencies between pairs of subpasses.",
			"items": {
				"type": "object",
				"required": [
					"sourceSubpass",
					"destinationSubpass",
					"sourceStages",
					"destinationStages",
					"sourceAccess",
					"destinationAccess"
				],
				"additionalProperties": false,
				"properties": {
					"sourceSubpass": {
						"type": "integer",
						"minimum": -1,
						"description": "The subpass index of the first subpass in the dependency, or -1."
					},
					"destinationSubpass": {
						"type": "integer",
						"minimum": -1,
						"description": "The subpass index of the second subpass in the dependency, or -1."
					},
					"sourceStages": {
						"$ref": "#/$defs/PipelineStage",
						"description": "An array of pipeline stages specifying the source stage mask."
					},
					"destinationStages": {
						"$ref": "#/$defs/PipelineStage",
						"description": "An array of pipeline stages specifying the destination stage mask."
					},
					"sourceAccess": {
						"$ref": "#/$defs/Access",
						"description": "An array of access modifiers specifying the source access mask."
					},
					"destinationAccess": {
						"$ref": "#/$defs/Access",
						"description": "An array of access modifiers specifying the destination access mask."
					},
					"dependencyFlags": {
						"$ref": "#/$defs/DependencyFlags",
						"description": "An array of dependency flags.",
						"default": []
					}
				}
			}
		}
	},
	"$defs": {
		"DependencyFlags": {
			"type": "array",
			"items": {
				"enum": [
					"ByRegion",
					"DeviceGroup",
					"ViewLocal",
					"FeedbackLoopExt",
					"QueueFamilyOwnershipTransferUseAllStagesKhr",
					"AsymmetricEventKhr",
					"ViewLocalKhr",
					"DeviceGroupKhr"
				]
			}
		},
		"Access": {
			"type": "array",
			"items": {
				"enum": [
					"IndirectCommandRead",
					"IndexRead",
					"VertexAttributeRead",
					"UniformRead",
					"InputAttachmentRead",
					"ShaderRead",
					"ShaderWrite",
					"ColorAttachmentRead",
					"ColorAttachmentWrite",
					"DepthStencilAttachmentRead",
					"DepthStencilAttachmentWrite",
					"TransferRead",
					"TransferWrite",
					"HostRead",
					"HostWrite",
					"MemoryRead",
					"MemoryWrite",
					"None",
					"TransformFeedbackWriteExt",
					"TransformFeedbackCounterReadExt",
					"TransformFeedbackCounterWriteExt",
					"ConditionalRenderingReadExt",
					"ColorAttachmentReadNoncoherentExt",
					"AccelerationStructureReadKhr",
					"AccelerationStructureWriteKhr",
					"FragmentDensityMapReadExt",
					"FragmentShadingRateAttachmentReadKhr",
					"CommandPreprocessReadExt",
					"CommandPreprocessWriteExt",
					"ShadingRateImageReadNv",
					"AccelerationStructureReadNv",
					"AccelerationStructureWriteNv",
					"CommandPreprocessReadNv",
					"CommandPreprocessWriteNv",
					"NoneKhr"
				]
			}
		},
		"PipelineStage": {
			"type": "array",
			"items": {
				"enum": [
					"TopOfPipe",
					"DrawIndirect",
					"VertexInput",
					"VertexShader",
					"TessellationControlShader",
					"TessellationEvaluationShader",
					"GeometryShader",
					"FragmentShader",
					"EarlyFragmentTests",
					"LateFragmentTests",
					"ColorAttachmentOutput",
					"ComputeShader",
					"Transfer",
					"BottomOfPipe",
					"Host",
					"AllGraphics",
					"AllCommands",
					"None",
					"TransformFeedbackExt",
					"ConditionalRenderingExt",
					"AccelerationStructureBuildKhr",
					"RayTracingShaderKhr",
					"FragmentDensityProcessExt",
					"FragmentShadingRateAttachmentKhr",
					"TaskShaderExt",
					"MeshShaderExt",
					"CommandPreprocessExt",
					"ShadingRateImageNv",
					"RayTracingShaderNv",
					"AccelerationStructureBuildNv",
					"TaskShaderNv",
					"MeshShaderNv",
					"CommandPreprocessNv",
					"NoneKhr"
				]
			}
		},
		"AttachmentLoadOp": {
			"enum": ["Load", "Clear", "DontCare", "None"]
		},
		"AttachmentStoreOp": {
			"enum": ["Store", "DontCare", "None"]
		},
		"PipelineBindPoint": {
			"enum": [
				"Graphics",
				"Compute",
				"ExecutionGraphAmdx",
				"RayTracing",
				"SubpassShadingHuawei",
				"DataGraphArm",
				"RayTracingNv"
